{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Annual anime studio closures, TDB data — uses 05_studio_closures_timeline.csv",

  "width": "container",
  "height": 280,
  "padding": {"top": 10, "right": 30, "bottom": 30, "left": 50},

  "data": {
    "url": "data/05_studio_closures_timeline.csv",
    "format": {"type": "csv", "parse": {"closures_count": "number"}}
  },

  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": null,
      "axis": {"labelAngle": 0, "labelPadding": 8}
    },
    "y": {
      "field": "closures_count",
      "type": "quantitative",
      "title": "Studios closed",
      "axis": {"grid": true},
      "scale": {"domain": [0, 18]}
    }
  },

  "layer": [
    {
      "mark": {"type": "bar", "width": 28, "cornerRadiusEnd": 3},
      "encoding": {
        "color": {
          "field": "kind",
          "type": "nominal",
          "scale": {
            "domain": ["full", "record", "partial"],
            "range": ["#1A1716", "#D63838", "#A88B3D"]
          },
          "legend": null
        }
      }
    },
    {
      "mark": {"type": "text", "align": "center", "baseline": "bottom", "dy": -5, "fontSize": 11, "font": "IBM Plex Mono", "color": "#1A1716"},
      "encoding": {
        "text": {"field": "closures_count"}
      }
    },
    {
      "transform": [{"filter": "datum.annotation != null && datum.annotation != ''"}],
      "mark": {"type": "text", "align": "center", "baseline": "bottom", "dy": -22, "fontSize": 9, "font": "IBM Plex Mono", "fontStyle": "italic"},
      "encoding": {
        "text": {"field": "annotation"},
        "color": {
          "field": "kind", "type": "nominal",
          "scale": {"domain": ["full", "record", "partial"], "range": ["#1A1716", "#D63838", "#A88B3D"]},
          "legend": null
        }
      }
    }
  ]
}
