{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Annual anime studio closures, TDB data",

  "width": "container",
  "height": 280,
  "padding": {"top": 10, "right": 30, "bottom": 30, "left": 50},

  "data": {
    "values": [
      {"year": "2018", "closures": 16, "kind": "record"},
      {"year": "2023", "closures": 8,  "kind": "full"},
      {"year": "2024", "closures": 10, "kind": "full"},
      {"year": "2025", "closures": 8,  "kind": "partial"}
    ]
  },

  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": null,
      "axis": {"labelAngle": 0, "labelPadding": 8}
    },
    "y": {
      "field": "closures",
      "type": "quantitative",
      "title": "Studios closed",
      "axis": {"grid": true},
      "scale": {"domain": [0, 18]}
    }
  },

  "layer": [
    {
      "mark": {"type": "bar", "width": 28, "cornerRadiusEnd": 3},
      "encoding": {
        "color": {
          "field": "kind",
          "type": "nominal",
          "scale": {
            "domain": ["full", "record", "partial"],
            "range": ["#1A1716", "#D63838", "#A88B3D"]
          },
          "legend": null
        }
      }
    },
    {
      "mark": {"type": "text", "align": "center", "baseline": "bottom", "dy": -5, "fontSize": 11, "font": "IBM Plex Mono", "color": "#1A1716"},
      "encoding": {
        "text": {"field": "closures"}
      }
    },
    {
      "comment": "Annotation for 2018 record",
      "data": {
        "values": [
          {"year": "2018", "closures": 16, "note": "all-time record"}
        ]
      },
      "mark": {"type": "text", "align": "center", "baseline": "bottom", "dy": -22, "fontSize": 9, "font": "IBM Plex Mono", "color": "#D63838", "fontStyle": "italic"},
      "encoding": {
        "text": {"field": "note"}
      }
    },
    {
      "comment": "Annotation for 2025 partial",
      "data": {
        "values": [
          {"year": "2025", "closures": 8, "note": "Jan–Sep only"}
        ]
      },
      "mark": {"type": "text", "align": "center", "baseline": "bottom", "dy": -22, "fontSize": 9, "font": "IBM Plex Mono", "color": "#A88B3D", "fontStyle": "italic"},
      "encoding": {
        "text": {"field": "note"}
      }
    }
  ]
}
