{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Anime studios by employee count - Teikoku Databank 2023 survey of 317 companies",

  "width": "container",
  "height": 300,
  "padding": {"top": 20, "right": 30, "bottom": 30, "left": 60},

  "data": {
    "url": "data/04b_studio_employees.csv",
    "format": {"type": "csv", "parse": {"studio_count": "number"}}
  },

  "encoding": {
    "x": {
      "field": "size_label",
      "type": "ordinal",
      "sort": ["5 or fewer", "6 to 20", "21 to 50", "51 to 100", "more than 100"],
      "title": "Number of employees",
      "axis": {"labelAngle": 0, "labelPadding": 8, "labelFontSize": 11, "labelFont": "Manrope", "titleFont": "Manrope", "titleColor": "#5A524F", "titleFontSize": 11}
    },
    "y": {
      "field": "studio_count",
      "type": "quantitative",
      "title": "Number of studios",
      "scale": {"domain": [0, 120]},
      "axis": {"grid": true, "gridColor": "#E6DFD0", "titleColor": "#5A524F"}
    }
  },

  "layer": [
    {
      "mark": {"type": "bar", "width": 50, "color": "#D63838", "opacity": 0.9},
      "encoding": {
        "tooltip": [
          {"field": "size_label", "type": "ordinal", "title": "Studio size"},
          {"field": "studio_count", "type": "quantitative", "title": "Studios"},
          {"field": "cumulative_pct", "type": "quantitative", "title": "Cumulative %"}
        ]
      }
    },
    {
      "mark": {"type": "text", "baseline": "bottom", "dy": -6, "fontSize": 12, "font": "IBM Plex Mono", "color": "#1A1716", "fontWeight": 500},
      "encoding": {
        "text": {"field": "studio_count"}
      }
    }
  ]
}
