{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Anime studios by employee count, TDB 2023 survey of 317 companies",

  "width": "container",
  "height": 280,
  "padding": {"top": 10, "right": 30, "bottom": 30, "left": 90},

  "data": {
    "url": "data/04_tdb2023_studio_size_distribution.csv",
    "format": {"type": "csv", "parse": {"studio_count": "number"}}
  },

  "transform": [
    {"filter": "datum.category === 'employees'"},
    {"calculate": "{'<=5': '5 or fewer', '6-20': '6 to 20', '21-50': '21 to 50', '51-100': '51 to 100', '>100': 'more than 100'}[datum.bucket]", "as": "size_label"}
  ],

  "encoding": {
    "y": {
      "field": "size_label",
      "type": "ordinal",
      "sort": ["5 or fewer", "6 to 20", "21 to 50", "51 to 100", "more than 100"],
      "title": null,
      "axis": {"labelPadding": 8, "labelFontSize": 12}
    },
    "x": {
      "field": "studio_count",
      "type": "quantitative",
      "title": "Number of studios",
      "axis": {"grid": true}
    }
  },

  "layer": [
    {
      "mark": {"type": "bar", "height": 36, "color": "#D63838", "cornerRadiusEnd": 2}
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 6, "fontSize": 11, "font": "IBM Plex Mono", "color": "#1A1716"},
      "encoding": {
        "text": {"field": "studio_count"}
      }
    }
  ]
}
