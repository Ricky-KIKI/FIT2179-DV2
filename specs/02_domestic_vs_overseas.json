{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Domestic vs overseas anime market revenue, 2020-2024",
  "width": "container",
  "height": 340,
  "padding": {"top": 10, "right": 90, "bottom": 30, "left": 50},

  "data": {
    "url": "data/02_domestic_vs_overseas.csv",
    "format": {"type": "csv", "parse": {"year": "number", "value": "number"}}
  },

  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": null,
      "axis": {"labelAngle": 0, "labelPadding": 8}
    },
    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Trillion yen",
      "scale": {"domain": [0, 2.5]}
    },
    "color": {
      "field": "segment",
      "type": "nominal",
      "scale": {
        "domain": ["Domestic", "Overseas"],
        "range": ["#1A1716", "#D63838"]
      },
      "legend": null
    }
  },

  "layer": [
    {
      "mark": {"type": "line", "strokeWidth": 2.5, "point": {"filled": true, "size": 70}},
      "encoding": {
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "segment", "type": "nominal", "title": "Market"},
          {"field": "value", "type": "quantitative", "format": ".3f", "title": "Trillion yen"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.year == 2024"}],
      "mark": {"type": "text", "align": "left", "dx": 8, "fontSize": 11, "font": "Manrope", "fontWeight": 600},
      "encoding": {
        "text": {"field": "segment"}
      }
    }
  ]
}
