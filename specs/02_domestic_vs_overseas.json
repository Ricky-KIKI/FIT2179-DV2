{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Domestic vs overseas anime market revenue, 2020-2024",
  "width": "container",
  "height": 340,
  "padding": {"top": 10, "right": 90, "bottom": 30, "left": 50},

  "data": {
    "url": "data/01_aja_market_timeseries.csv",
    "format": {"type": "csv", "parse": {"year": "number", "total_market_jpy_trillion": "number", "domestic_jpy_trillion": "number", "overseas_jpy_trillion": "number"}}
  },

  "transform": [
    {"filter": "datum.domestic_jpy_trillion != null && datum.domestic_jpy_trillion != ''"},
    {"fold": ["domestic_jpy_trillion", "overseas_jpy_trillion"], "as": ["segment_raw", "value"]},
    {"calculate": "datum.segment_raw === 'domestic_jpy_trillion' ? 'Domestic' : 'Overseas'", "as": "segment"}
  ],

  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": null,
      "axis": {"labelAngle": 0, "labelPadding": 8}
    },
    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Trillion yen",
      "scale": {"domain": [0, 2.5]}
    },
    "color": {
      "field": "segment",
      "type": "nominal",
      "scale": {
        "domain": ["Domestic", "Overseas"],
        "range": ["#1A1716", "#D63838"]
      },
      "legend": null
    }
  },

  "layer": [
    {
      "mark": {"type": "line", "strokeWidth": 2.5, "point": {"filled": true, "size": 70}}
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 8, "fontSize": 11, "font": "Manrope", "fontWeight": 600},
      "encoding": {
        "text": {"field": "segment"},
        "x": {"field": "year", "type": "ordinal", "aggregate": "max"},
        "y": {"field": "value", "type": "quantitative", "aggregate": {"argmax": "year"}}
      }
    }
  ]
}
