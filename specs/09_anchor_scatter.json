{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Anchor studios: founding year vs notable works count; non-Tokyo highlighted",

  "width": "container",
  "height": 420,
  "padding": {"top": 30, "right": 30, "bottom": 40, "left": 60},

  "data": {
    "url": "data/06_anchor_studios.csv",
    "format": {"type": "csv", "parse": {"founded_year": "number", "works_count": "number"}}
  },

  "encoding": {
    "x": {
      "field": "founded_year",
      "type": "quantitative",
      "title": "Year founded",
      "scale": {"domain": [1945, 2025]},
      "axis": {"format": "d", "grid": true, "tickCount": 8}
    },
    "y": {
      "field": "works_count",
      "type": "quantitative",
      "title": "Notable works in this collection",
      "scale": {"domain": [0, 6]},
      "axis": {"grid": true, "values": [1, 2, 3, 4, 5]}
    }
  },

  "layer": [
    {
      "mark": {"type": "circle", "size": 220, "opacity": 0.9, "stroke": "#FAF7F0", "strokeWidth": 2},
      "encoding": {
        "color": {
          "field": "location_class",
          "type": "nominal",
          "scale": {
            "domain": ["Tokyo 23-ku", "Tokyo (not 23-ku)", "Kyoto", "Toyama"],
            "range": ["#1A1716", "#A88B3D", "#D63838", "#D63838"]
          },
          "legend": {
            "title": null,
            "orient": "bottom-right",
            "labelFont": "Manrope",
            "labelFontSize": 11,
            "symbolSize": 100,
            "offset": 10
          }
        },
        "tooltip": [
          {"field": "studio_name", "type": "nominal", "title": "Studio"},
          {"field": "founded_year", "type": "quantitative", "title": "Founded"},
          {"field": "location_class", "type": "nominal", "title": "Location"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.studio_name == 'Studio Ghibli'"}],
      "mark": {
        "type": "text", "align": "left", "dx": 10, "dy": 14,
        "fontSize": 10, "font": "Manrope", "fontWeight": 600, "color": "#1A1716"
      },
      "encoding": {
        "text": {"field": "studio_name", "type": "nominal"}
      }
    },
    {
      "transform": [{"filter": "datum.studio_name == 'Kyoto Animation'"}],
      "mark": {
        "type": "text", "align": "right", "dx": -10, "dy": 3,
        "fontSize": 10, "font": "Manrope", "fontWeight": 600, "color": "#1A1716"
      },
      "encoding": {
        "text": {"field": "studio_name", "type": "nominal"}
      }
    },
    {
      "transform": [{"filter": "datum.location_class != 'Tokyo 23-ku' && datum.studio_name != 'Studio Ghibli' && datum.studio_name != 'P.A. Works' && datum.studio_name != 'Kyoto Animation'"}],
      "mark": {
        "type": "text", "align": "left", "dx": 10, "dy": 3,
        "fontSize": 10, "font": "Manrope", "fontWeight": 600, "color": "#1A1716"
      },
      "encoding": {
        "text": {"field": "studio_name", "type": "nominal"}
      }
    },
    {
      "transform": [{"filter": "datum.studio_name == 'P.A. Works'"}],
      "mark": {
        "type": "text", "align": "left", "dx": 10, "dy": -10,
        "fontSize": 10, "font": "Manrope", "fontWeight": 600, "color": "#1A1716"
      },
      "encoding": {
        "text": {"field": "studio_name", "type": "nominal"}
      }
    },
    {
      "transform": [{"filter": "datum.studio_name == 'Toei Animation' || datum.studio_name == 'Mushi Production' || datum.studio_name == 'CloverWorks'"}],
      "mark": {
        "type": "text", "align": "left", "dx": 10, "dy": 3,
        "fontSize": 10, "font": "Manrope", "fontWeight": 500, "color": "#5A524F"
      },
      "encoding": {
        "text": {"field": "studio_name", "type": "nominal"}
      }
    },
    {
      "transform": [{"filter": "datum.studio_name == 'MAPPA'"}],
      "mark": {
        "type": "text", "align": "left", "dx": 10, "dy": -10,
        "fontSize": 10, "font": "Manrope", "fontWeight": 500, "color": "#5A524F"
      },
      "encoding": {
        "text": {"field": "studio_name", "type": "nominal"}
      }
    }
  ]
}
