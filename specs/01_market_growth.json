{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "AJA anime industry market size, verified annual data 2009 + 2014-2024",
  "width": "container",
  "height": 320,
  "padding": {"top": 10, "right": 24, "bottom": 30, "left": 50},

  "data": {
    "url": "data/01_aja_market_timeseries.csv",
    "format": {"type": "csv", "parse": {"year": "number", "total_market_jpy_trillion": "number", "domestic_jpy_trillion": "number", "overseas_jpy_trillion": "number"}}
  },

  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "title": null,
      "scale": {"domain": [2008, 2025]},
      "axis": {"format": "d", "labelAngle": 0, "labelPadding": 8, "values": [2009, 2012, 2015, 2018, 2021, 2024], "tickCount": 6}
    },
    "y": {
      "field": "total_market_jpy_trillion",
      "type": "quantitative",
      "title": "Trillion yen",
      "scale": {"domain": [0, 4.5]}
    }
  },

  "layer": [
    {
      "mark": {"type": "area", "opacity": 0.15, "color": "#D63838"}
    },
    {
      "mark": {
        "type": "line", "color": "#D63838", "strokeWidth": 2.5,
        "point": {"filled": true, "size": 70, "color": "#D63838"}
      }
    },
    {
      "transform": [{"filter": "datum.label != null && datum.label != '' && datum.anchor == 'left'"}],
      "mark": {"type": "text", "align": "left", "baseline": "bottom", "dx": 8, "dy": -10, "fontSize": 10, "font": "IBM Plex Mono", "color": "#1A1716"},
      "encoding": {
        "text": {"field": "label"},
        "y": {"field": "total_market_jpy_trillion", "type": "quantitative"}
      }
    },
    {
      "transform": [{"filter": "datum.label != null && datum.label != '' && datum.anchor == 'right'"}],
      "mark": {"type": "text", "align": "right", "baseline": "bottom", "dx": -8, "dy": -10, "fontSize": 10, "font": "IBM Plex Mono", "color": "#1A1716"},
      "encoding": {
        "text": {"field": "label"},
        "y": {"field": "total_market_jpy_trillion", "type": "quantitative"}
      }
    }
  ]
}
