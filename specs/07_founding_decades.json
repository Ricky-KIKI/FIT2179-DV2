{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Anime studios by decade of founding, TDB 2023 survey",

  "width": "container",
  "height": 300,
  "padding": {"top": 10, "right": 30, "bottom": 30, "left": 50},

  "data": {
    "url": "data/04_tdb2023_studio_size_distribution.csv",
    "format": {"type": "csv", "parse": {"studio_count": "number"}}
  },

  "transform": [
    {"filter": "datum.category === 'founded_decade'"}
  ],

  "encoding": {
    "x": {
      "field": "bucket",
      "type": "ordinal",
      "sort": ["1960s", "1970s", "1980s", "1990s", "2000s", "2010s", "2020s"],
      "title": null,
      "axis": {"labelAngle": 0, "labelPadding": 8, "labelFontSize": 12}
    },
    "y": {
      "field": "studio_count",
      "type": "quantitative",
      "title": "Studios founded",
      "axis": {"grid": true}
    }
  },

  "layer": [
    {
      "mark": {"type": "bar", "width": 36, "cornerRadiusEnd": 3},
      "encoding": {
        "color": {
          "condition": {"test": "datum.bucket == '2010s'", "value": "#D63838"},
          "value": "#1A1716"
        }
      }
    },
    {
      "mark": {"type": "text", "align": "center", "baseline": "bottom", "dy": -6, "fontSize": 11, "font": "IBM Plex Mono", "fontWeight": 500},
      "encoding": {
        "text": {"field": "studio_count"},
        "color": {
          "condition": {"test": "datum.bucket == '2010s'", "value": "#D63838"},
          "value": "#1A1716"
        }
      }
    }
  ]
}
