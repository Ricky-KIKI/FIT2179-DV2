{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Anime studio lineage — uses 08_lineage_nodes.csv and 08_lineage_edges.csv",

  "width": "container",
  "height": 540,
  "padding": {"top": 20, "right": 20, "bottom": 20, "left": 20},

  "layer": [
    {
      "data": {"url": "data/08_lineage_edges.csv", "format": {"type": "csv", "parse": {"x1": "number", "y1": "number", "x2": "number", "y2": "number"}}},
      "mark": {"type": "rule", "color": "#C8B89E", "strokeWidth": 1.4},
      "encoding": {
        "x":  {"field": "x1", "type": "quantitative", "scale": {"domain": [0, 800]}, "axis": null},
        "y":  {"field": "y1", "type": "quantitative", "scale": {"domain": [500, 0]}, "axis": null},
        "x2": {"field": "x2"},
        "y2": {"field": "y2"}
      }
    },

    {
      "data": {"url": "data/08_lineage_nodes.csv", "format": {"type": "csv", "parse": {"x": "number", "y": "number", "founded_year": "number"}}},
      "mark": {"type": "circle", "size": 700, "stroke": "#FAF7F0", "strokeWidth": 3},
      "encoding": {
        "x": {"field": "x", "type": "quantitative", "scale": {"domain": [0, 800]}, "axis": null},
        "y": {"field": "y", "type": "quantitative", "scale": {"domain": [500, 0]}, "axis": null},
        "color": {
          "field": "level", "type": "nominal",
          "scale": {
            "domain": ["ancestor", "first_gen", "active"],
            "range": ["#1A1716", "#A88B3D", "#D63838"]
          },
          "legend": null
        },
        "tooltip": [
          {"field": "studio_name", "type": "nominal", "title": "Studio"},
          {"field": "founded_year", "type": "quantitative", "title": "Founded"}
        ]
      }
    },

    {
      "data": {"url": "data/08_lineage_nodes.csv", "format": {"type": "csv", "parse": {"x": "number", "y": "number", "founded_year": "number"}}},
      "mark": {"type": "text", "align": "center", "baseline": "bottom", "dy": -18, "fontSize": 11, "font": "Manrope", "fontWeight": 600, "color": "#1A1716"},
      "encoding": {
        "x": {"field": "x", "type": "quantitative", "scale": {"domain": [0, 800]}, "axis": null},
        "y": {"field": "y", "type": "quantitative", "scale": {"domain": [500, 0]}, "axis": null},
        "text": {"field": "studio_name"}
      }
    },

    {
      "data": {"url": "data/08_lineage_nodes.csv", "format": {"type": "csv", "parse": {"x": "number", "y": "number", "founded_year": "number"}}},
      "mark": {"type": "text", "align": "center", "baseline": "top", "dy": 22, "fontSize": 9, "font": "IBM Plex Mono", "color": "#5A524F"},
      "encoding": {
        "x": {"field": "x", "type": "quantitative", "scale": {"domain": [0, 800]}, "axis": null},
        "y": {"field": "y", "type": "quantitative", "scale": {"domain": [500, 0]}, "axis": null},
        "text": {"field": "founded_year"}
      }
    },

    {
      "data": {
        "values": [
          {"header": "ANCESTOR", "x": 100, "y": 510},
          {"header": "FIRST GENERATION", "x": 280, "y": 510},
          {"header": "MODERN", "x": 480, "y": 510},
          {"header": "RECENT", "x": 680, "y": 510}
        ]
      },
      "mark": {"type": "text", "align": "center", "fontSize": 10, "font": "IBM Plex Mono", "fontWeight": 500, "color": "#A88B3D"},
      "encoding": {
        "x": {"field": "x", "type": "quantitative", "scale": {"domain": [0, 800]}, "axis": null},
        "y": {"field": "y", "type": "quantitative", "scale": {"domain": [500, 0]}, "axis": null},
        "text": {"field": "header"}
      }
    }
  ],

  "config": {"view": {"stroke": null}}
}
