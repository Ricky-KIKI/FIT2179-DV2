{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Overseas anime market by region (licensing contracts), AJA 2022, with streaming-revenue contrast annotation",

  "width": "container",
  "height": 260,
  "padding": {"top": 20, "right": 20, "bottom": 20, "left": 20},

  "data": {
    "url": "data/09_overseas_market_by_region.csv",
    "format": {"type": "csv", "parse": {"share_pct": "number", "order": "number"}}
  },

  "encoding": {
    "y": {
      "field": "region",
      "type": "nominal",
      "sort": ["Asia", "Europe", "C / S America", "Oceania", "Middle East", "Africa", "Eastern Europe", "North America"],
      "title": null,
      "axis": {"labelFont": "Manrope", "labelFontSize": 12, "labelFontWeight": 500, "labelColor": "#1A1716", "domain": false, "ticks": false, "labelPadding": 10}
    },
    "x": {
      "field": "share_pct",
      "type": "quantitative",
      "title": "Share of overseas licensing contracts (%)",
      "scale": {"domain": [0, 35]},
      "axis": {"grid": true, "gridColor": "#E6DFD0", "gridDash": [2, 3], "labelFont": "IBM Plex Mono", "labelFontSize": 10, "titleFont": "Manrope", "titleFontSize": 11, "titleColor": "#5A524F"}
    }
  },

  "layer": [
    {
      "mark": {"type": "bar", "height": 18},
      "encoding": {
        "color": {
          "field": "highlight",
          "type": "nominal",
          "scale": {
            "domain": ["top", "other", "last"],
            "range": ["#D63838", "#A88B3D", "#9E1B1B"]
          },
          "legend": null
        },
        "tooltip": [
          {"field": "region", "type": "nominal", "title": "Region"},
          {"field": "share_pct", "type": "quantitative", "format": ".1f", "title": "Contract share (%)"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 6, "fontSize": 11, "font": "IBM Plex Mono", "color": "#1A1716", "fontWeight": 500},
      "encoding": {
        "text": {"field": "share_pct", "type": "quantitative", "format": ".1f"}
      }
    }
  ]
}
