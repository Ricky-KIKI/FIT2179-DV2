{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Where the overseas anime money comes from — AJA 2022",

  "width": "container",
  "height": 200,
  "padding": {"top": 50, "right": 30, "bottom": 50, "left": 30},

  "data": {
    "url": "data/09_overseas_market_by_region.csv",
    "format": {"type": "csv", "parse": {"share_pct": "number", "order": "number", "x_start": "number", "x_end": "number"}}
  },

  "transform": [
    {"calculate": "(datum.x_start + datum.x_end) / 2", "as": "x_center"}
  ],

  "layer": [
    {
      "mark": {"type": "bar", "stroke": "#FAF7F0", "strokeWidth": 1.5, "height": 60},
      "encoding": {
        "x":  {"field": "x_start", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null},
        "x2": {"field": "x_end"},
        "color": {
          "field": "region", "type": "nominal", "sort": null,
          "scale": {"range": ["#D63838", "#C46A2E", "#A88B3D", "#8C7438", "#6C5F38", "#5A524F", "#9B9B95", "#C8B89E"]},
          "legend": null
        },
        "tooltip": [
          {"field": "region", "type": "nominal"},
          {"field": "share_pct", "type": "quantitative", "format": ".1f", "title": "Share (%)"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.share_pct >= 7"}],
      "mark": {"type": "text", "color": "#FAF7F0", "fontWeight": 600, "fontSize": 12, "font": "IBM Plex Mono"},
      "encoding": {
        "x": {"field": "x_center", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null},
        "text": {"field": "share_pct", "type": "quantitative", "format": ".1f"}
      }
    },
    {
      "transform": [{"filter": "datum.share_pct >= 7"}],
      "mark": {"type": "text", "color": "#1A1716", "fontWeight": 600, "fontSize": 11, "font": "Manrope", "dy": -40, "align": "center"},
      "encoding": {
        "x": {"field": "x_center", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null},
        "text": {"field": "region", "type": "nominal"}
      }
    },
    {
      "transform": [{"filter": "datum.region == 'Africa'"}],
      "mark": {"type": "text", "color": "#5A524F", "fontWeight": 500, "fontSize": 9, "font": "IBM Plex Mono", "dy": 42, "align": "center"},
      "encoding": {
        "x": {"field": "x_center", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null},
        "text": {"field": "region", "type": "nominal"}
      }
    },
    {
      "transform": [{"filter": "datum.region == 'Africa'"}],
      "mark": {"type": "text", "color": "#5A524F", "fontWeight": 500, "fontSize": 9, "font": "IBM Plex Mono", "dy": 54, "align": "center"},
      "encoding": {
        "x": {"field": "x_center", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null},
        "text": {"field": "share_pct", "type": "quantitative", "format": ".1f"}
      }
    },
    {
      "transform": [{"filter": "datum.region == 'Eastern Europe'"}],
      "mark": {"type": "text", "color": "#5A524F", "fontWeight": 500, "fontSize": 9, "font": "IBM Plex Mono", "dy": 64, "align": "center"},
      "encoding": {
        "x": {"field": "x_center", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null},
        "text": {"field": "region", "type": "nominal"}
      }
    },
    {
      "transform": [{"filter": "datum.region == 'Eastern Europe'"}],
      "mark": {"type": "text", "color": "#5A524F", "fontWeight": 500, "fontSize": 9, "font": "IBM Plex Mono", "dy": 76, "align": "center"},
      "encoding": {
        "x": {"field": "x_center", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null},
        "text": {"field": "share_pct", "type": "quantitative", "format": ".1f"}
      }
    },
    {
      "transform": [{"filter": "datum.region == 'North America'"}],
      "mark": {"type": "text", "color": "#5A524F", "fontWeight": 500, "fontSize": 9, "font": "IBM Plex Mono", "dy": 42, "align": "center"},
      "encoding": {
        "x": {"field": "x_center", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null},
        "text": {"field": "region", "type": "nominal"}
      }
    },
    {
      "transform": [{"filter": "datum.region == 'North America'"}],
      "mark": {"type": "text", "color": "#5A524F", "fontWeight": 500, "fontSize": 9, "font": "IBM Plex Mono", "dy": 54, "align": "center"},
      "encoding": {
        "x": {"field": "x_center", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null},
        "text": {"field": "share_pct", "type": "quantitative", "format": ".1f"}
      }
    }
  ]
}
